  "info": {
    "title": "CRM Backend API",
    "description": "The core API for CRM Lead Management and Project Coordination.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "crm_session",
        "description": "Session cookie (HttpOnly)"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@crm.local",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "Admin@123",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ApiResponseDto": {
        "type": "object",
        "properties": {
          "rid": {
            "type": "string",
            "example": "s-success-rid"
          },
          "statusCode": {
            "type": "number",
            "example": 200
          },
          "data": {
            "type": "object"
          },
          "message": {
            "type": "string",
            "example": "Operation successful"
          },
          "meta": {
            "type": "object",
            "example": {
              "timestamp": "2026-03-28T07:44:00Z"
            }
          }
        },
        "required": [
          "rid",
          "statusCode",
          "data",
          "message",
          "meta"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {}
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {}
      },
      "CreateUserDto": {
        "type": "object",
